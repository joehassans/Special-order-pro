// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
// PostgreSQL for production (Railway). Set DATABASE_URL in Railway.
// For local dev: use a local Postgres or free Neon/Supabase instance.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// --- Special order store (v2 data model) ---
//
// Authoritative store for app-managed special-order state (statuses, item
// attributes, notification log). Rows bootstrap from the legacy
// position-keyed metafields (namespace "custom") on first sight; after
// that, sync only refreshes Shopify-owned fields and app writes go through
// the DB first. Metafields are still mirrored for backward compatibility.

model SpecialOrder {
  id        String @id @default(cuid())
  shop      String
  // GID of the Shopify Order or DraftOrder this row mirrors.
  shopifyId String
  // "ORDER" | "DRAFT_ORDER"
  kind      String
  name      String

  contactStatus String?
  overallStatus String?
  // Derived at sync time from Shopify financial fields ("Paid in Full", ...).
  paymentStatus String?
  // Draft order status (OPEN / INVOICE_SENT / COMPLETED); null for orders.
  shopifyStatus String?
  note          String?

  customerShopifyId String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?

  // When a draft converts to a real order, links the two rows.
  convertedFromDraftId String?

  shopifyCreatedAt DateTime?
  syncedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())

  items         SpecialOrderItem[]
  notifications NotificationLog[]

  @@unique([shop, shopifyId])
  @@index([shop, overallStatus])
  @@index([shop, createdAt])
}

model SpecialOrderItem {
  id             String       @id @default(cuid())
  specialOrderId String
  specialOrder   SpecialOrder @relation(fields: [specialOrderId], references: [id], onDelete: Cascade)

  // Stable Shopify LineItem / DraftOrderLineItem GID. This replaces the
  // fragile 1-based position that keys the legacy metafields.
  shopifyLineItemId String?
  // 1-based index matching the legacy lineitem_{N}_* metafield keys.
  position          Int

  title        String
  variantTitle String?
  quantity     Int     @default(1)

  // Per-item order status (Not Ordered / Ordered / Received / ...).
  status String?
  // JSON array of { key, value } item attributes (Brand, Size, Color, ...).
  attributes Json?

  adjustmentType    String?
  exchangedForTitle String?

  @@unique([specialOrderId, position])
  @@index([shopifyLineItemId])
}

/// Per-shop store identity used on printed order summaries and customer
/// emails (logo, address, hours, contact info). Shops without a row fall
/// back to the legacy hard-coded config until they save one in Settings.
model ShopProfile {
  id        String @id @default(cuid())
  shop      String @unique
  storeName String?
  address   String?
  hours     String?
  phone     String?
  website   String?
  instagram String?
  // Absolute URL, or a path served by this app (e.g. "/store-logo.png").
  logoUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-shop item detail fields shown in POS/admin editors (e.g. a bike
/// shop uses "Frame Color", "Rim Size" instead of the apparel defaults).
model ShopItemField {
  id       String @id @default(cuid())
  shop     String
  label    String
  position Int

  @@unique([shop, label])
  @@index([shop, position])
}

model NotificationLog {
  id             String       @id @default(cuid())
  specialOrderId String
  specialOrder   SpecialOrder @relation(fields: [specialOrderId], references: [id], onDelete: Cascade)

  // e.g. "email_ready_pickup"
  type           String
  recipientEmail String
  employeeNote   String?
  sentAt         DateTime
  createdAt      DateTime @default(now())

  @@index([specialOrderId, sentAt])
}
