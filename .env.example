# Database (required)
DATABASE_URL=

# Shopify app (from Partner Dashboard / shopify app env)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=

# --- Notify customer emails ---
#
# Railway Hobby/Free block outbound SMTP to Gmail. Use Resend (HTTPS) in production:
# https://resend.com — create API key, verify your sending domain, then:
RESEND_API_KEY=
# Must match a verified domain in Resend (e.g. "Joe Hassan's Special Orders <orders@yourdomain.com>")
EMAIL_FROM=
#
# Local dev (or Railway Pro+ if you use SMTP): Gmail + App Password
# https://support.google.com/accounts/answer/185833
GMAIL_USER=joehassans.orders@gmail.com
GMAIL_APP_PASSWORD=
# Optional: 587 (default) or 465
# GMAIL_SMTP_PORT=465
